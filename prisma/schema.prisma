// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

enum AuthProvider {
  LOCAL
  GOOGLE
}

model User {
  id        String         @id @default(uuid())
  email     String         @unique
  password  String?
  firstName String
  lastName  String
  accounts  OAuthAccount[]
  vehicles  Vehicle[]

  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt @default(now())

  @@map("users")
}

model OAuthAccount {
  id                String       @id @default(uuid())
  provider          AuthProvider
  providerAccountId String
  userId            String
  user              User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt

  @@unique([provider, providerAccountId])
  @@index([userId])
  @@map("oauth_accounts")
}

model Make {
  id              String @id @default(uuid())
  title           String
  slug            String @unique
  externalId      Int? @unique
  isSynced        Boolean? @default(false)
  models          Model[]
  vehicles        Vehicle[]

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt @default(now())

  @@map("makes")
}

model Model {
  id            String @id @default(uuid())
  name          String
  externalId    Int? @unique
  makeId        String
  make          Make @relation(fields: [makeId], references: [id])
  vehicles      Vehicle[]

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt @default(now())

  @@unique([name, makeId])
  @@map("models")
}

model Vehicle {
  id              String @id @default(uuid())
  vin             String @unique

  makeId          String
  make            Make @relation(fields: [makeId], references: [id])

  modelId         String
  model           Model @relation(fields: [modelId], references: [id])

  year            Int
  fuelType        String
  currentMileage  Int
  licensePlate    String? @unique
  user            User @relation(fields: [userId], references: [id])
  userId          String
  serviceLogs            ServiceLog[]
  lastMileageUpdate DateTime   @default(now())

  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  @@map("vehicles")
}

model Category {
  id            String @id @default(uuid())
  title         String @unique
  isSystem      Boolean @default(false)
  slug          String @unique
  serviceLogs   ServiceLog[]

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt @default(now())

  @@map("service_log_categories")
}

enum ServiceLogStatus {
  ACTIVE
  CORRECTED
  DELETED
}

model ServiceLog {
  id             String @id @default(uuid())
  status         ServiceLogStatus @default(ACTIVE)
  description    String?
  mileage        Int
  total          Decimal @default(0)
  subTotal       Decimal @default(0)
  date           DateTime @default(now())
  correctedLogId String? @unique
  correctReason  String?
  parts          Part[]
  category       Category? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  categoryId     String?
  vehicle        Vehicle @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  vehicleId      String

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt @default(now())
  
  @@map("service_logs")
}

model Part {
  id            String @id @default(uuid())
  name          String
  brand         String?
  description   String?
  partNumber    String?
  price         Decimal
  quantity      Int @default(1)
  serviceLogId  String
  serviceLog    ServiceLog @relation(fields: [serviceLogId], references: [id], onDelete: Cascade)

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt @default(now())
  
  @@map("parts")
}